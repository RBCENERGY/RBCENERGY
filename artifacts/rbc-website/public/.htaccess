# RBC GmbH Website — Single-Page-App Routing (Apache / DomainFactory)
# Alle Pfade außer existierenden Dateien/Ordnern und /api/ auf index.html umleiten.

RewriteEngine On
RewriteBase /

RewriteRule ^index\.html$ - [L]
RewriteCond %{REQUEST_URI} ^/api/ [OR]
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]
RewriteRule . /index.html [L]

# Sinnvolle Cache-Header: Assets mit Hash lange cachen, index.html nie
<IfModule mod_headers.c>
  <FilesMatch "index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
  <FilesMatch "\.(js|css|png|jpg|jpeg|webp|svg|woff2?)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>
